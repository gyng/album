{
  "name": "album",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "index:update": "(cd ../index; bash ./do-full-index.sh)",
    "index:embeddings:update": "(cd ../index; bash ./do-embeddings-index.sh)",
    "publish:wizard": "node ./bin/publish-wizard.cjs",
    "cleanup:media-cache": "node ./bin/cleanup-optimised-media.cjs",
    "prepare:build-manifest": "node ./bin/write-build-manifest.cjs",
    "deploy:vercel": "npx vercel build --prod && npx vercel deploy --prebuilt --prod",
    "dev": "npm run prepare:build-manifest && npm run prepare:feeds && next dev --turbopack",
    "benchmark:warm": "node ./bin/warm-build-benchmark.cjs",
    "benchmark:warm:strict": "ALBUM_BENCHMARK_FAIL_ON_BUDGET=1 node ./bin/warm-build-benchmark.cjs",
    "benchmark:route": "node --experimental-strip-types ./bin/map-route-benchmark.ts",
    "prepare:feeds": "node ./bin/generate-feeds.cjs",
    "build": "npm run cleanup:media-cache && npm run prepare:build-manifest && npm run prepare:feeds && next build && echo 'build done'",
    "build:profile": "npm run cleanup:media-cache && npm run prepare:build-manifest && npm run prepare:feeds && ALBUM_BUILD_PROFILE=1 next build && echo 'build done'",
    "start": "next start",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "eslint . && npm run typecheck",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "jest",
    "test:seo": "jest --runInBand test/seo.test.tsx test/alt.test.ts test/feed.test.ts services/albumFeed.test.ts",
    "test:ci": "timeout 60s jest --maxWorkers=50% && npm run lint",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:reuse": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "screenshot": "playwright test --config=playwright.screenshot.config.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@nivo/core": "^0.99.0",
    "@nivo/sankey": "^0.99.0",
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8",
    "@tanstack/react-query": "^5.95.2",
    "@vercel/analytics": "^2.0.1",
    "coi-serviceworker": "^0.1.7",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fraction.js": "^5.3.4",
    "image-size": "^2.0.2",
    "maplibre-gl": "^5.21.1",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-map-gl": "^8.1.0",
    "sharp": "^0.34.5",
    "sqlite3": "^6.0.1",
    "use-debounce": "^10.1.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "usehooks-ts": {
      "react": "^19.2.4"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^24.0.0"
  }
}
